          "apiKey": "AIzaSyBvTPOu-ccL2aP6pxKKtW4PJKThnOA7zVI"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "865aa665-efa9-4842-9f74-0817aa91acf2"
      }
    },
    "plugins": [
      "expo-font"
    ]
